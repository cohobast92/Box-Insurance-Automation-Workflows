N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http

N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me
N8N_ENCRYPTION_KEY=replace_with_long_random_string

N8N_LOG_LEVEL=info
GENERIC_TIMEZONE=UTC

# Endpoint exposed by your Box MCP server
BOX_MCP_SSE_ENDPOINT=http://host.docker.internal:8001/sse

# Used by OpenAI nodes through n8n credential configuration
OPENAI_API_KEY=

# Path inside the n8n container for the sample claims JSON used by
# doc-gen-claim-generation/Box DocGen Claim Generation.json
CLAIMS_SAMPLE_DATA_PATH=/files/sample_claims_data.json

